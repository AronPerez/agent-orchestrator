#!/bin/zsh
# Stop/start the AO web/mobile UI launchd jobs. Reversible.
# (The daemon is intentionally NOT supervised here: a launchd-spawned daemon
# can't read ~/Desktop project repos due to macOS TCC. Start it from a terminal.)
#   ao-svc down     # bootout the web/mobile jobs (clean stop, no respawn)
#   ao-svc up       # bootstrap the web/mobile jobs
#   ao-svc status   # show which jobs are loaded
#   ao-svc reload   # rebuild daemon from source, deploy to ~/.ao/bin/ao, kickstart it
set -u
dom="gui/$(id -u)"
LA="$HOME/Library/LaunchAgents"
repo="$HOME/dev/ag-orc"                                                  # symlink to the checkout (dev-setup.sh)
cache_bin="${XDG_CACHE_HOME:-$HOME/.cache}/aoagents/agent-orchestrator/bin/ao"
services=(dev.agent-orchestrator.lan-web dev.agent-orchestrator.mobile-web dev.agent-orchestrator.phone-bridge)

case "${1:-status}" in
  down)
    for s in $services; do
      launchctl bootout "$dom/$s" 2>/dev/null && echo "down: $s" || echo "down: $s (not loaded)"
    done
    ;;
  up)
    for s in $services; do
      launchctl bootstrap "$dom" "$LA/$s.plist" 2>/dev/null && echo "up:   $s" || echo "up:   $s (already loaded / failed)"
    done
    ;;
  status)
    launchctl list | grep agent-orchestrator || echo "(no agent-orchestrator jobs loaded)"
    ;;
  reload)
    # daemon runs its own KeepAlive plist (not in $services); rebuild + redeploy + kickstart it.
    mkdir -p "$HOME/.ao/bin"
    "$repo/scripts/daemon-build.sh" \
      && cp -f "$cache_bin" "$HOME/.ao/bin/ao" \
      && launchctl kickstart -k "$dom/dev.agent-orchestrator.daemon" \
      && echo "reload: daemon rebuilt + live on :3001" \
      || { echo "reload: FAILED" >&2; exit 1; }
    ;;
  *)
    echo "usage: ao-svc {up|down|status|reload}" >&2; exit 2
    ;;
esac
