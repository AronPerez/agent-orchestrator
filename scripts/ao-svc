#!/bin/zsh
# Stop/start the AO daemon + web/mobile UI launchd jobs. Reversible.
# The daemon is supervised here too, via its KeepAlive plist (~/.ao/ao-daemon.sh
# pins AO_ALLOWED_ORIGINS to the current LAN IP — the durable equivalent of
# `AO_ALLOWED_ORIGINS=http://<lan-ip>:3000 ao daemon`). Requires the ao binary to
# have Full Disk Access so a launchd-spawned daemon can read ~/Desktop repos.
#   ao-svc down     # bootout all jobs (clean stop, no respawn)
#   ao-svc up       # bootstrap all jobs (daemon first)
#   ao-svc status   # show which jobs are loaded
#   ao-svc reload   # rebuild daemon from source, deploy to ~/.ao/bin/ao, kickstart it
set -u
dom="gui/$(id -u)"
LA="$HOME/Library/LaunchAgents"
repo="$HOME/dev/ag-orc"                                                  # symlink to the checkout (dev-setup.sh)
cache_bin="${XDG_CACHE_HOME:-$HOME/.cache}/aoagents/agent-orchestrator/bin/ao"
services=(dev.agent-orchestrator.daemon dev.agent-orchestrator.lan-web dev.agent-orchestrator.mobile-web dev.agent-orchestrator.phone-bridge)

case "${1:-status}" in
  down)
    for s in $services; do
      launchctl bootout "$dom/$s" 2>/dev/null && echo "down: $s" || echo "down: $s (not loaded)"
    done
    ;;
  up)
    for s in $services; do
      launchctl bootstrap "$dom" "$LA/$s.plist" 2>/dev/null && echo "up:   $s" || echo "up:   $s (already loaded / failed)"
    done
    ;;
  status)
    launchctl list | grep agent-orchestrator || echo "(no agent-orchestrator jobs loaded)"
    ;;
  reload)
    # rebuild + redeploy the daemon binary + kickstart it in place (up/down manage its lifecycle).
    mkdir -p "$HOME/.ao/bin"
    "$repo/scripts/daemon-build.sh" \
      && cp -f "$cache_bin" "$HOME/.ao/bin/ao.new" \
      && mv -f "$HOME/.ao/bin/ao.new" "$HOME/.ao/bin/ao" \
      && launchctl kickstart -k "$dom/dev.agent-orchestrator.daemon" \
      && echo "reload: daemon rebuilt + live on :3001" \
      || { echo "reload: FAILED" >&2; exit 1; }
    ;;
  *)
    echo "usage: ao-svc {up|down|status|reload}" >&2; exit 2
    ;;
esac
